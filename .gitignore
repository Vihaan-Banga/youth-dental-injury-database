# Data — DO NOT commit raw downloads
# These should be re-downloadable from the original source
data/raw/neiss/*.csv
data/raw/neiss/*.tsv
data/raw/neiss/*.zip
data/raw/neiss/*.rda
data/raw/papers/*.pdf
data/raw/surveillance_reports/*.pdf

# Keep the folder structure though
!data/raw/neiss/.gitkeep
!data/raw/papers/.gitkeep
!data/raw/surveillance_reports/.gitkeep

# Outputs are regenerable — commit only final versions
outputs/figures/draft_*
outputs/tables/draft_*

# Environment
.env
*.local

# Logs
*.log

# Claude Code local dev config (not part of the dataset)
.claude/

# Internal working docs (strategy notes, AI-session logs, screening scratch) — not part of the public scientific artifact
internal/
